<UserControl x:Class="Battleship.MVVM.View.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Battleship.MVVM.View"
             mc:Ignorable="d"
             d:DesignHeight="460"
             d:DesignWidth="800">

    <Grid HorizontalAlignment="Center"
          VerticalAlignment="Center">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Border Width="400"
                    Height="200"
                    CornerRadius="10">

                <Border.Background>
                    <LinearGradientBrush StartPoint="0 0"
                                         EndPoint="1 2">

                        <GradientStop Color="#1FADFF"
                                      Offset="0.0" />

                        <GradientStop Color="#007EF5"
                                      Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel>
                    <StackPanel.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontSize"
                                    Value="18" />
                            <Setter Property="Margin"
                                    Value="20 10 10 0" />
                            <Setter Property="Foreground"
                                    Value="White" />
                        </Style>
                    </StackPanel.Resources>

                    <TextBlock Text="Controls"
                               FontSize="28" />

                    <TextBlock Text="R: Lets you rotate ship" />

                    <TextBlock Text="Left click to place / interact" />

                    <TextBlock Text="Right click to pick up ship" />
                </StackPanel>
            </Border>

            <Border Width="200"
                    Height="200"
                    CornerRadius="10"
                    Margin="40 0 0 0">

                <Border.Background>
                    <LinearGradientBrush StartPoint="0 0"
                                         EndPoint="1 2">

                        <GradientStop Color="#FFCF70"
                                      Offset="0.0" />

                        <GradientStop Color="#FFBC47"
                                      Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel>
                    <StackPanel.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontSize"
                                    Value="20" />
                            <Setter Property="Margin"
                                    Value="15 15 0 45" />
                        </Style>
                    </StackPanel.Resources>

                    <TextBlock Text="Made using WPF &#10;with MVVM pattern." />
                    <TextBlock Text="Created for &#10;a school project." />
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Width="130"
                Height="40"
                CornerRadius="10"
                Grid.Row="1"
                Margin="510,52,0,-92"
                BorderBrush="#47A6FF"
                BorderThickness="2">

            <Border.Background>
                <LinearGradientBrush StartPoint="0 0"
                                     EndPoint="1 2">

                    <GradientStop Color="#232031"
                                  Offset="0.0" />

                    <GradientStop Color="#1B1825"
                                  Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <Hyperlink NavigateUri="https://github.com/tutenik"
                           RequestNavigate="Hyperlink_RequestNavigate"
                           Foreground="White"
                           TextDecorations="None">
                    <Run Text="Made by Tutenik" />
                </Hyperlink>
            </TextBlock>
        </Border>
    </Grid>
</UserControl>