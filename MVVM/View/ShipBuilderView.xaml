<UserControl x:Class="Battleship.MVVM.View.ShipBuilderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Battleship.MVVM.View"
             xmlns:viewModel="clr-namespace:Battleship.MVVM.ViewModel"
             xmlns:converter="clr-namespace:Battleship.MVVM.Converters"
             mc:Ignorable="d"
             d:DesignHeight="460"
             d:DesignWidth="840">

    <UserControl.Resources>
        <converter:BrushToBoolConverter x:Key="BrushToBool" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal">
                <Label Content="Select brush:"
                       Foreground="White"
                       FontSize="20"
                       Margin="0 15 15 0" />
                <StackPanel>
                    <ToggleButton Content="Ship"
                                  Style="{StaticResource ToggleButtonBrushTheme}"
                                  IsChecked="{Binding SelectedBrush,
                          Converter={StaticResource BrushToBool},
                          ConverterParameter=ShipBrush}" />
                    <ToggleButton Content="Eraser"
                                  Style="{StaticResource ToggleButtonBrushTheme}"
                                  IsChecked="{Binding SelectedBrush,
                          Converter={StaticResource BrushToBool},
                          ConverterParameter=EraserBrush}" />

                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1"
                        VerticalAlignment="Center"
                        Margin="15 15">

                <Label Content="Enter ship set name:"
                       Foreground="White"
                       FontSize="20" />

                <TextBox Text="{Binding ShipSetName, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="20" />

            </StackPanel>

            <Button x:Name="SaveShip"
                    Content="Save ship set"
                    Grid.Row="2"
                    Width="180"
                    FontSize="20"
                    Margin="10"
                    Style="{StaticResource RoundedGradientButton}"
                    Command="{Binding SaveShipsCommand}">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0 0"
                                         EndPoint="1 2">
                        <GradientStop Color="#4eff91"
                                      Offset="0" />
                        <GradientStop Color="#FF117737"
                                      Offset="0.7" />
                    </LinearGradientBrush>
                </Button.Background>

                <Button.Foreground>
                    <SolidColorBrush Color="White" />
                </Button.Foreground>
            </Button>
        </Grid>

        <ContentControl Content="{Binding GameBoard}"
                        Grid.Column="1"
                        Width="420"
                        Height="420"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
    </Grid>
</UserControl>
