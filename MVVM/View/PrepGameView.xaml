<UserControl x:Class="Battleship.MVVM.View.PrepGameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Battleship.MVVM.View"
             xmlns:behaviour="clr-namespace:Battleship.MVVM.Behaviours"
             xmlns:viewModel="clr-namespace:Battleship.MVVM.ViewModel"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:helper="clr-namespace:Battleship.MVVM.Helpers"
             xmlns:converter="clr-namespace:Battleship.MVVM.Converters"
             mc:Ignorable="d"
             d:DesignHeight="460"
             d:DesignWidth="800"
             x:Name="Window">

    <UserControl.Resources>
        <converter:AddConverter x:Key="AddConverter"/>
        <converter:RectConverter x:Key="RectConverter" />
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="R"
                    Command="{Binding RotateShipCommand}" />
    </UserControl.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="3*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ListBox ItemsSource="{Binding Ships}"
                 SelectedItem="{Binding SelectedShip, Mode=TwoWay}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Margin="5"
                            Padding="10"
                            Background="Transparent">
                        <Grid>
                            <ItemsControl ItemsSource="{Binding Cells}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Grid helper:GridHelper.Rows="{Binding Rows}"
                                              helper:GridHelper.Columns="{Binding Columns}"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemContainerStyle>
                                    <Style>
                                        <Setter Property="Grid.Row"
                                                Value="{Binding Row}" />
                                        <Setter Property="Grid.Column"
                                                Value="{Binding Column}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="Black"
                                                BorderThickness="2" >
                                            
                                            <Image Source="{Binding ImagePath}"
                                                   MaxWidth="25"
                                                   MaxHeight="25" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Grid.Row="1">
            <Button 
                    Content="Randomize"
                    Command="{Binding RandomizeCommand}"
                    Style="{StaticResource RoundedGradientButton}">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0 0"
                                         EndPoint="1 2">
                        <GradientStop Color="#4e99ff"
                                      Offset="0.1" />
                        <GradientStop Color="#FF117737"
                                      Offset="1" />
                    </LinearGradientBrush>
                </Button.Background>

                <Button.Foreground>
                    <SolidColorBrush Color="White" />
                </Button.Foreground>
            </Button>
            
            <Button Content="Ready"
                    Command="{Binding ReadyCommand}"
                    Style="{StaticResource RoundedGradientButton}">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0 0"
                                         EndPoint="1 2">
                        <GradientStop Color="#4eff91"
                                      Offset="0" />
                        <GradientStop Color="#FF117737"
                                      Offset="0.7" />
                    </LinearGradientBrush>
                </Button.Background>

                <Button.Foreground>
                    <SolidColorBrush Color="White" />
                </Button.Foreground>
            </Button>
                    
        </StackPanel>
        
        <ContentControl Grid.Column="1"
                        Grid.RowSpan="99"
                        x:Name="GameGrid"
                        Content="{Binding GameBoardVM}"
                        Width="400"
                        Height="400" />

        <Canvas Grid.Column="1"
                Grid.RowSpan="99"
                Width="{Binding ActualWidth, ElementName=GameGrid}"
                Height="{Binding ActualHeight, ElementName=GameGrid}"
                Background="Transparent">

            <ItemsControl ItemsSource="{Binding HoverShip.Cells}"
                          Canvas.Top="{Binding TopCanvasPosition}"
                          Canvas.Left="{Binding LeftCanvasPosition}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="{Binding HoverShip.Rows}"
                                     Columns="{Binding HoverShip.Columns}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewModel:CellViewModel}">
                        <Image Source="{Binding ImagePath}"
                               Width="40"
                               Height="40" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <i:Interaction.Behaviors>
                <behaviour:MouseTrackingBehavior MousePosition="{Binding MousePosition}" />
            </i:Interaction.Behaviors>

            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseMove">
                    <i:InvokeCommandAction Command="{Binding MouseMoveCommand}">
                    </i:InvokeCommandAction>
                </i:EventTrigger>
                
                <i:EventTrigger EventName="MouseLeftButtonUp">
                    <i:InvokeCommandAction Command="{Binding MouseLeftButtonUpCommand}" />
                </i:EventTrigger>
                
                <i:EventTrigger EventName="MouseRightButtonDown">
                    <i:InvokeCommandAction Command="{Binding MouseRightButtonDownCommand}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </Canvas>
    </Grid>
</UserControl>
