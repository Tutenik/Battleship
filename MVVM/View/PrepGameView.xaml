<UserControl x:Class="Battleship.MVVM.View.PrepGameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Battleship.MVVM.View"
             xmlns:viewModel="clr-namespace:Battleship.MVVM.ViewModel"
             mc:Ignorable="d"
             d:DesignHeight="460"
             d:DesignWidth="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <ListBox ItemsSource="{Binding Ships}"
                 SelectedItem="{Binding SelectedShip, Mode=TwoWay}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Margin="5"
                            Padding="10"
                            Background="LightGray">
                        <Grid>
                            <ItemsControl ItemsSource="{Binding Cells}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="{Binding Rows}"
                                                     Columns="{Binding Columns}" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="Black"
                                                BorderThickness="3">
                                            <Image Source="{Binding ImagePath}"
                                                   MaxWidth="20"
                                                   MaxHeight="20"/>

                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <ContentControl Grid.Column="1"
                        Content="{Binding GameBoard}"
                        Width="400"
                        Height="400" />
    </Grid>
</UserControl>
