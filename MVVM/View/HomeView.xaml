<UserControl x:Class="Battleship.MVVM.View.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Battleship.MVVM.View"
             xmlns:viewModel="clr-namespace:Battleship.MVVM.ViewModel"
             mc:Ignorable="d"
             d:DesignHeight="460"
             d:DesignWidth="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="55" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Label Content="Select ship set:"
               Grid.Row="0"
               Margin="35 15 0 0"
               FontSize="20"
               Foreground="White" />

        <ListBox Grid.Row="1"
                 Margin="35"
                 ItemsSource="{Binding ShipSets}"
                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                 BorderThickness="0">

            <ListBox.Resources>
                <Style TargetType="ScrollBar">
                    <Setter Property="OverridesDefaultStyle"
                            Value="True" />
                    <Setter Property="Width"
                            Value="10" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="#1E1E1E">

                                    <Track x:Name="PART_Track">
                                        <Track.Thumb>
                                            <Thumb x:Name="Thumb"
                                                   Background="#47A6FF">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="5" />
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>

                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.Resources>

            <ListBox.Background>
                <LinearGradientBrush StartPoint="0 0"
                                     EndPoint="1 2">

                    <GradientStop Color="#232031"
                                  Offset="0.0" />

                    <GradientStop Color="#1B1825"
                                  Offset="1.0" />
                </LinearGradientBrush>
            </ListBox.Background>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Margin="5"
                            Padding="10"
                            CornerRadius="10"
                            BorderBrush="#47A6FF"
                            BorderThickness="2">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0 0"
                                                 EndPoint="1 2">

                                <GradientStop Color="#36304B"
                                              Offset="0.0" />

                                <GradientStop Color="#2D283E"
                                              Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="{Binding Name}"
                                   FontSize="20"
                                   Foreground="White" />
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>



        <Button Content="Play"
                Grid.Column="1"
                Grid.Row="1"
                Width="200"
                Height="65"
                FontSize="40"
                Command="{Binding PlayGameCommand}"
                Style="{StaticResource RoundedGradientButton}">

            <Button.Background>
                <LinearGradientBrush StartPoint="0 0"
                                     EndPoint="1 2">

                    <GradientStop Color="#1FADFF"
                                  Offset="0.0" />

                    <GradientStop Color="#007EF5"
                                  Offset="1.0" />
                </LinearGradientBrush>
            </Button.Background>

            <Button.Foreground>
                <SolidColorBrush Color="White" />
            </Button.Foreground>
        </Button>

    </Grid>
</UserControl>
