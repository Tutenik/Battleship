<UserControl x:Class="Battleship.MVVM.View.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Battleship.MVVM.View"
             xmlns:viewModel="clr-namespace:Battleship.MVVM.ViewModel"
             mc:Ignorable="d"
             d:DesignHeight="460"
             d:DesignWidth="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <ListBox ItemsSource="{Binding ShipSets}"
                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Margin="5"
                            Padding="10"
                            Background="LightGray">
                        <TextBlock Text="{Binding Name}" />
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Width="400"
                Height="200"
                Grid.Column="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0 0"
                                     EndPoint="1 2">

                    <GradientStop Color="#5bc3ff"
                                  Offset="0.0" />

                    <GradientStop Color="#3aa0ff"
                                  Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <Border.Clip>
                <RectangleGeometry RadiusX="10"
                                   RadiusY="10"
                                   Rect="0 0 400 200" />
            </Border.Clip>

            <Button Content="Play"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="40"
                    Margin="20 10 10 0"
                    Command="{Binding PlayGameCommand}" />

        </Border>
    </Grid>
</UserControl>
