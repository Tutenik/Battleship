<Window x:Class="Battleship.MVVM.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Battleship.MVVM.View"
        xmlns:viewModel="clr-namespace:Battleship.MVVM.ViewModel"
        xmlns:converter="clr-namespace:Battleship.MVVM.Converters"
        mc:Ignorable="d"
        Height="600"
        Width="920"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="True">

    <Window.DataContext>
        <viewModel:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <converter:RectConverter x:Key="RectConverter" />
    </Window.Resources>

    <Border Background="#272537"
            x:Name="RootBorder">
        <Border.Clip>
            <RectangleGeometry RadiusX="20"
                               RadiusY="20">
                <RectangleGeometry.Rect>
                    <MultiBinding Converter="{StaticResource RectConverter}">
                        <Binding ElementName="RootBorder"
                                 Path="ActualWidth" />
                        <Binding ElementName="RootBorder"
                                 Path="ActualHeight" />
                    </MultiBinding>
                </RectangleGeometry.Rect>
            </RectangleGeometry>

        </Border.Clip>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="75" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Ličta -->
            <Grid Background="#22202f">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="1"
                           MouseLeftButtonDown="TextBlock_MouseLeftButtonDown" />

                <Button x:Name="btnMinimize"
                        Content="🗕"
                        Width="40"
                        Height="40"
                        BorderBrush="Transparent"
                        Background="Transparent"
                        Foreground="White"
                        Grid.Column="2"
                        Click="btnMinimize_Click" />

                <Button x:Name="btnMaximize"
                        Content="🗖"
                        Width="40"
                        Height="40"
                        BorderBrush="Transparent"
                        Background="Transparent"
                        Foreground="White"
                        Grid.Column="3"
                        Click="btnMaximize_Click" />

                <Button x:Name="btnClose"
                        Content="❌"
                        Width="40"
                        Height="40"
                        BorderBrush="Transparent"
                        Background="Transparent"
                        Foreground="White"
                        Grid.Column="4"
                        Click="btnClose_Click" />
            </Grid>

            <!--Nav bar-->
            <StackPanel Orientation="Horizontal"
                        Grid.Row="1">
                <TextBlock Text="Battleship"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Foreground="White"
                           FontSize="22"
                           Margin="20 0 20 0" />

                <RadioButton Content="Home"
                             Foreground="White"
                             FontSize="14"
                             Width="100"
                             Style="{StaticResource MenuButtomTheme}"
                             IsChecked="True"
                             Command="{Binding HomeViewCommand}" />

                <RadioButton Content="Ship&#10;Builder"
                             Foreground="White"
                             FontSize="14"
                             Width="100"
                             Style="{StaticResource MenuButtomTheme}"
                             Command="{Binding ShipBuilderCommand}" />

                <RadioButton Content="Settings"
                             Foreground="White"
                             FontSize="14"
                             Width="100"
                             Style="{StaticResource MenuButtomTheme}"
                             Command="{Binding SettingsViewCommand}" />

                <RadioButton Content="About"
                             Foreground="White"
                             FontSize="14"
                             Width="100"
                             Style="{StaticResource MenuButtomTheme}"
                             Command="{Binding AboutViewCommand}" />
            </StackPanel>

            <!-- Content window -->
            <ContentControl Grid.Row="2"
                            Margin="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Content="{Binding CurrentView}"
                            Height="460"
                            Width="840"/>
        </Grid>
    </Border>
</Window>
